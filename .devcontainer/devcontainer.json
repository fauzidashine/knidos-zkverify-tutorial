{
  "name": "Knidos zkVerify Challenge",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": true,
      "docker-dashboards": false
    },
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    }
  },
  "postCreateCommand": "pip3 install --quiet -r requirements.txt && echo '✅ Ready. Run: python3 scripts/auto-verify.py'",
  "portsAttributes": {
    "7878": {
      "label": "Knidos Challenge",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode-remote.remote-containers",
        "ms-python.python"
      ]
    }
  }
}
